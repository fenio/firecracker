# tns-csi profile: networking + k3s + storage protocols (NVMe-oF, iSCSI, NFS, SMB).
# For testing https://github.com/fenio/tns-csi in Firecracker microVMs.
# Merged on top of Firecracker's recommended microvm config.

# ── PCI VirtIO transport (required by --enable-pci) ─────────
CONFIG_BLK_MQ_PCI=y
CONFIG_PCI=y
CONFIG_PCI_MMCONFIG=y
CONFIG_PCI_MSI=y
CONFIG_PCIEPORTBUS=y
CONFIG_VIRTIO_PCI=y
CONFIG_PCI_HOST_COMMON=y
CONFIG_PCI_HOST_GENERIC=y

# ── Netfilter (iptables/nftables) ──────────────────────────
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NFT_COMPAT=y
CONFIG_NFT_CT=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_CHAIN_NAT=y
CONFIG_NFT_COUNTER=y
CONFIG_NFT_LOG=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_REJECT=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_STATE=y
CONFIG_NETFILTER_XT_MATCH_COMMENT=y
CONFIG_NETFILTER_XT_MATCH_MULTIPORT=y
CONFIG_NETFILTER_XT_MATCH_MARK=y
CONFIG_NETFILTER_XT_MATCH_STATISTIC=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_RECENT=y
CONFIG_NETFILTER_XT_MATCH_IPVS=y
CONFIG_NETFILTER_XT_TARGET_MARK=y
CONFIG_NETFILTER_XT_TARGET_REDIRECT=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_TARGET_NOTRACK=y
CONFIG_NETFILTER_XT_TARGET_LOG=y
CONFIG_NETFILTER_XT_NAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_MANGLE=y
CONFIG_IP_NF_RAW=y
CONFIG_IP_NF_TARGET_REJECT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_FILTER=y
CONFIG_IP6_NF_NAT=y
CONFIG_IP6_NF_MANGLE=y
CONFIG_IP6_NF_RAW=y
CONFIG_IP6_NF_TARGET_REJECT=y
CONFIG_NETFILTER_XT_MATCH_POLICY=y
CONFIG_NETFILTER_XT_MATCH_PHYSDEV=y

# ── Conntrack / NAT helpers ──────────────────────────────────
CONFIG_NF_CT_PROTO_DCCP=y
CONFIG_NF_CT_PROTO_SCTP=y
CONFIG_NF_CT_PROTO_UDPLITE=y
CONFIG_NF_CONNTRACK_FTP=y
CONFIG_NF_CONNTRACK_TFTP=y

# ── Bridge (CNI) ──────────────────────────────────────────────
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_NF_CONNTRACK_BRIDGE=y
CONFIG_BRIDGE_NF_EBTABLES=y

# ── VXLAN/overlay networking (Flannel CNI) ────────────────────
CONFIG_VXLAN=y
CONFIG_UDP_TUNNEL=y
CONFIG_NET_UDP_TUNNEL=y

# ── IP Virtual Server (kube-proxy IPVS mode) ─────────────────
CONFIG_IP_VS=y
CONFIG_IP_VS_PROTO_TCP=y
CONFIG_IP_VS_PROTO_UDP=y
CONFIG_IP_VS_RR=y
CONFIG_IP_VS_WRR=y
CONFIG_IP_VS_SH=y
CONFIG_IP_VS_NFCT=y

# ── cgroup v2 ──────────────────────────────────────────────────
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_HUGETLB=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_BPF=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CPUSETS=y

# ── Overlay filesystem (containerd) ────────────────────────────
CONFIG_OVERLAY_FS=y

# ── Veth (container networking) ────────────────────────────────
CONFIG_VETH=y

# ── Network device types ─────────────────────────────────────
CONFIG_DUMMY=y
CONFIG_TUN=y
CONFIG_MACVLAN=y

# ── Namespaces / security ────────────────────────────────────
CONFIG_POSIX_MQUEUE=y
CONFIG_KEYS=y
CONFIG_FHANDLE=y
CONFIG_USER_NS=y
CONFIG_NET_NS=y
CONFIG_PID_NS=y
CONFIG_IPC_NS=y
CONFIG_UTS_NS=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_NETLINK_DIAG=y
CONFIG_INET_DIAG=y

# ── NVMe-oF (NVMe over Fabrics) ─────────────────────────────
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_FABRICS=y
CONFIG_NVME_TCP=y
CONFIG_NVME_FC=y
CONFIG_CONFIGFS_FS=y
CONFIG_NVME_TARGET=y
CONFIG_NVME_TARGET_TCP=y
CONFIG_NVME_TARGET_LOOP=y

# ── iSCSI ────────────────────────────────────────────────────
CONFIG_ISCSI_TCP=y
CONFIG_SCSI=y
CONFIG_SCSI_LOWLEVEL=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_ISCSI_ATTRS=y
CONFIG_ISCSI_BOOT_SYSFS=y
CONFIG_ISCSI_TARGET=y
CONFIG_TARGET_CORE=y

# ── NFS ──────────────────────────────────────────────────────
CONFIG_NFS_FS=y
CONFIG_NFS_V4=y
CONFIG_NFS_V4_1=y
CONFIG_NFS_V4_2=y
CONFIG_NFSD=y
CONFIG_NFSD_V4=y
CONFIG_SUNRPC=y
CONFIG_SUNRPC_GSS=y
CONFIG_LOCKD=y
CONFIG_GRACE_PERIOD=y

# ── SMB/CIFS ─────────────────────────────────────────────────
CONFIG_CIFS=y
CONFIG_CIFS_POSIX=y
CONFIG_CIFS_STATS2=y
CONFIG_CIFS_XATTR=y

# ── Block devices ────────────────────────────────────────────
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_NBD=y
