# Minimal profile: boot + shell only, no networking.
# Merged on top of Firecracker's recommended microvm config.

# ── PCI VirtIO transport (required by --enable-pci) ─────────
CONFIG_BLK_MQ_PCI=y
CONFIG_PCI=y
CONFIG_PCI_MMCONFIG=y
CONFIG_PCI_MSI=y
CONFIG_PCIEPORTBUS=y
CONFIG_VIRTIO_PCI=y
CONFIG_PCI_HOST_COMMON=y
CONFIG_PCI_HOST_GENERIC=y
